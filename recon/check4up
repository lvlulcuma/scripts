#!/usr/bin/env bash

lookup() {
	local keywords=("usr" "user" "username" "admin" "root" "pass" "passwd" "password")
	local url_regex='^https?://[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}(/.*)?$'

	while read -r url; do
	    # Skip blank lines, comments, and invalid URLs
	    [[ -z "$url" ]] && continue
	    [[ "$url" == \#* ]] && continue
	    [[ "$url" =~ $url_regex ]] || { printf '\e[38;5;8m[SKIPPED]\e[0m not a valid URL: %s\n' "$url"; continue; }

	    printf '~ \e[38;5;6m%s\e[0m\n' "$url"
	    result=$(curl -s "$url")
	    
	    for keyword in "${keywords[@]}"; do
		if echo "$result" | grep -qEi "\b$keyword\b"; then
		    printf '\e[38;5;2m[SUCCESS]\e[0m \e[38;5;3m%s\e[0m \n' "$keyword"
		fi
	    done
	    #printf '\n'
	done
}

lookup < "$1"
